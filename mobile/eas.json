{
	"cli": {
		"version": ">= 12.0.0",
		"appVersionSource": "remote"
	},
	"build": {
		"development": {
			"developmentClient": true,
			"distribution": "internal",
			"env": {
				"EXPO_PUBLIC_API_URL": "https://appomarcheivoire.onrender.com"
			}
		},
		"preview": {
			"distribution": "internal",
			"android": {
				"buildType": "apk"
			},
			"env": {
				"EXPO_PUBLIC_API_URL": "https://appomarcheivoire.onrender.com"
			}
		},
		"production": {
			"autoIncrement": true,
			"android": {
				"buildType": "app-bundle"
			},
			"env": {
				"EXPO_PUBLIC_API_URL": "https://appomarcheivoire.onrender.com"
			}
		}
	}
}
